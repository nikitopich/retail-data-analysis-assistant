# Required — fail fast at startup if missing
GOOGLE_API_KEY=your-gemini-api-key
GCP_PROJECT=your-gcp-project-id

# Optional — BigQuery auth (only if you don't use `gcloud auth application-default login`)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Optional — per-agent models (defaults shown)
SUPERVISOR_MODEL=gemini-2.5-flash-lite
SQL_MODEL=gemini-3.5-flash
REPORT_MODEL=gemini-2.5-flash

# Optional — query guardrails
DEFAULT_LIMIT=100
MAX_BYTES_BILLED=1073741824            # 1 GiB cost-guard per query

# Optional — resilience / UX
RETRY_ATTEMPTS=3                       # SQL (re)generation budget
AFK_TIMEOUT_S=30                       # auto-cancel a pending delete confirmation
LLM_TIMEOUT_S=60                       # per-Gemini-request timeout (SDK retries disabled)

# Optional — local store / identity
DB_PATH=agentic.db
CURRENT_USER=default_user

# Optional — error verbosity. Same effect as `--debug`. Set to 1/true to show
# generated SQL, BigQuery error text and tracebacks; leave unset/empty for
# scenario messages only.
DEBUG=

# Optional — observability (Phoenix tracing). Same effect as `--trace`.
# Leave unset/empty to disable. Set to 1/true to launch an embedded Phoenix
# UI at http://localhost:6006 and trace every graph + LLM call.
TRACING=
# Optional — point at an already-running collector (`phoenix serve`) instead of
# the embedded one, so traces persist to disk across runs.
# PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
